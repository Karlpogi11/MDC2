# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — get these from: Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Supabase Edge Function secrets, set with:
#   supabase secrets set APP_URL=https://inventory.your-hostinger-domain.com
#   supabase secrets set CORS_ALLOWED_ORIGINS=https://inventory.your-hostinger-domain.com
# Keep localhost origins for local development by adding them comma-separated if needed.
APP_URL=https://inventory.your-hostinger-domain.com
CORS_ALLOWED_ORIGINS=https://inventory.your-hostinger-domain.com,http://localhost:5173,http://127.0.0.1:5173
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
