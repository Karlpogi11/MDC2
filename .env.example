# ── HOW TO USE THIS FILE ──────────────────────────────────────────────
# 1. Copy this file to both locations:
#      Frontend: cp .env.example .env.local
#      Backend:  cp .env.example backend/.env
# 2. Fill in your values (see each variable below)
# 3. NEVER commit .env or .env.local to git

# ── Frontend ──────────────────────────────────────────────────────────
# Backend API URL (used by all API calls)
#   Dev local:    http://localhost:3001/api
#   Production:   https://yourdomain.com/api
VITE_API_URL=http://localhost:3001/api

# ── Database ──────────────────────────────────────────────────────────
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example:   mysql://root@localhost:3307/mdc
DATABASE_URL=mysql://root@localhost:3306/mdc

# ── Authentication ────────────────────────────────────────────────────
# Change this to a strong random string in production!
JWT_SECRET=mdc-jwt-secret-change-in-production

# ── Server ────────────────────────────────────────────────────────────
# Backend port (default 3001)
PORT=3001
# Frontend URL (for CORS + email receipt links)
CORS_ORIGIN=http://localhost:5173

# ── Email (SMTP) ──────────────────────────────────────────────────────
# Used for dispatch notifications and packing lists.
# For Gmail: use an App Password (not your regular password).
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=your.email@gmail.com
SMTP_FROM_NAME="MDC"
